# Expo client
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions only
# Keep server-side secrets out of EXPO_PUBLIC_* variables.
OPENAI_API_KEY=your-openai-api-key
# The Supabase function runtime provides SUPABASE_SERVICE_ROLE_KEY by default.
# If you run the function in an environment without that injected secret, provide it there as a server-only secret.
