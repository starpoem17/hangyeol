# Expo client
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions only
# Keep server-side secrets out of EXPO_PUBLIC_* variables.
OPENAI_API_KEY=your-openai-api-key
# submit-concern currently also requires SUPABASE_SERVICE_ROLE_KEY because it
# uses a service-role client to call a service-role-only RPC helper.
# Keep that key in the function runtime only, never in Expo client env.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
